---
import type { AppcastRelease } from '../lib/appcast';

interface Props {
  release: AppcastRelease;
}

const { release } = Astro.props;
const label = release.channel === 'beta' ? 'Beta' : 'Latest';
---

<span
  class="inline-flex items-center gap-2 rounded-full border border-aerial-border bg-aerial-surface/60 px-3 py-1 text-xs font-medium text-aerial-text-muted"
>
  <span
    class:list={[
      'inline-block h-1.5 w-1.5 rounded-full',
      release.channel === 'beta' ? 'bg-aerial-link' : 'bg-aerial-accent',
    ]}
    aria-hidden="true"
  ></span>
  {label}: {release.version}
  <span class="text-aerial-text-dim">·</span>
  <span class="text-aerial-text-dim">{release.pubDateLabel}</span>
</span>
