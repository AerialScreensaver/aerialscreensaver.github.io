---
import type { ImageMetadata } from 'astro';
import MediaCard from './MediaCard.astro';

interface Props {
  title: string;
  summary: string;
  href?: string;
  image?: ImageMetadata;
  imageSrc?: string;
  video?: string;
  videoPoster?: string;
  alt?: string;
  placeholder?: 'image' | 'video';
}

const { title, summary, href, image, imageSrc, video, videoPoster, alt, placeholder } = Astro.props;
const hasMedia = Boolean(image || imageSrc || video || placeholder);
---

<div
  class:list={[
    'group rounded-2xl border border-aerial-border bg-aerial-surface/60 transition-all overflow-hidden',
    hasMedia ? 'p-3' : 'p-7',
    href && 'hover:border-aerial-accent/50 hover:bg-aerial-surface-hi/60',
  ]}
>
  {
    hasMedia && (
      <MediaCard
        image={image}
        imageSrc={imageSrc}
        video={video}
        videoPoster={videoPoster}
        alt={alt ?? title}
        placeholder={placeholder}
        placeholderLabel={title}
        cardAspect="4/3"
      />
    )
  }
  <div class={hasMedia ? 'p-4' : ''}>
    <h3 class="text-xl font-semibold text-aerial-text">
      {href ? <a href={href}>{title}</a> : title}
    </h3>
    <p class="mt-3 text-aerial-text-muted leading-relaxed">{summary}</p>
    {
      href && (
        <a
          href={href}
          class="mt-5 inline-flex items-center gap-1 text-sm text-aerial-link hover:text-aerial-link-hi"
        >
          Learn more
          <svg
            class="h-3 w-3 transition-transform group-hover:translate-x-0.5"
            viewBox="0 0 12 12"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M4.5 2.5 8 6l-3.5 3.5"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              fill="none"
            />
          </svg>
        </a>
      )
    }
  </div>
</div>
