---
const base = import.meta.env.BASE_URL;
const link = (path: string) => `${base.replace(/\/$/, '')}${path}`;
const year = new Date().getFullYear();
---

<footer class="mt-32 border-t border-aerial-border/60 bg-aerial-bg">
  <div class="mx-auto max-w-6xl px-6 py-12 grid gap-10 md:grid-cols-4 text-sm">
    <div class="md:col-span-2">
      <div class="flex items-center gap-2 text-aerial-text font-semibold text-base">
        <img
          src={link('/aerial-icon-64.png')}
          srcset={`${link('/aerial-icon-64.png')} 1x, ${link('/icon-192.png')} 3x`}
          width="28"
          height="28"
          alt=""
          class="h-7 w-7"
        />
        Aerial
      </div>
      <p class="mt-3 text-aerial-text-muted leading-relaxed max-w-md">
        Free and open-source. Maintained since 2017 by Guillaume Louel.
        If you enjoy Aerial, you can
        <a href="https://ko-fi.com/A0A32385Y" class="text-aerial-link hover:text-aerial-link-hi">
          buy me a coffee
        </a> or check the <a href={link('/expansions')} class="text-aerial-link hover:text-aerial-link-hi">Expansions</a> for extra videos, their authors contribute back to the project!
      </p>
    </div>

    <div>
      <div class="text-aerial-text font-semibold mb-3">Project</div>
      <ul class="space-y-2 text-aerial-text-muted">
        <li><a href={link('/features')} class="hover:text-aerial-text">Features</a></li>
        <li><a href={link('/release-notes')} class="hover:text-aerial-text">Release notes</a></li>
        <li><a href={link('/expansions')} class="hover:text-aerial-text">Expansions</a></li>
        <li><a href={link('/faq')} class="hover:text-aerial-text">FAQ</a></li>
        <li><a href={link('/legal')} class="hover:text-aerial-text">Legal</a></li>
      </ul>
    </div>

    <div>
      <div class="text-aerial-text font-semibold mb-3">Source</div>
      <ul class="space-y-2 text-aerial-text-muted">
        <li>
          <a href="https://github.com/AerialScreensaver/Aerial" class="hover:text-aerial-text">
            Aerial on GitHub
          </a>
        </li>
        <li>
          <a href="https://github.com/JohnCoates/Aerial" class="hover:text-aerial-text">
            Original repository (2015)
          </a>
        </li>
        <li>
          <a href="https://github.com/AerialScreensaver/Aerial/issues" class="hover:text-aerial-text">
            Report an issue
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-aerial-border/40">
    <div
      class="mx-auto max-w-6xl px-6 py-6 text-xs text-aerial-text-dim flex flex-wrap items-center justify-between gap-4"
    >
      <p>
        © {year} Guillaume Louel. Aerial is licensed under MIT. Auto-updates powered by
        <a href="https://sparkle-project.org/" class="text-aerial-text-muted hover:text-aerial-text">
          Sparkle
        </a>.
      </p>
      <p class="text-right">
        Apple, macOS, tvOS, Apple TV and Mac are trademarks of Apple Inc. Aerial is not affiliated with
        Apple.
      </p>
    </div>
  </div>
</footer>
