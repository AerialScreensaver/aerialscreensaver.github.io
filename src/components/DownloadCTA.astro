---
import type { AppcastRelease } from '../lib/appcast';
import { BETA_MIN_MACOS, BETA_RECOMMENDED_ON } from '../lib/appcast';

interface Props {
  release: AppcastRelease;
  variant?: 'primary' | 'large';
  tone?: 'solid' | 'outline';
  showMeta?: boolean;
  align?: 'start' | 'center';
  /** When set (and release is stable), renders a pointer line sending
   *  Golden Gate users to the beta. Callers pass it only when a beta exists. */
  betaPointerHref?: string;
}

const {
  release,
  variant = 'primary',
  tone = 'solid',
  showMeta = true,
  align = 'start',
  betaPointerHref,
} = Astro.props;

const sizeClass =
  variant === 'large'
    ? 'px-8 py-4 text-base'
    : 'px-6 py-3 text-sm';

const toneClasses =
  tone === 'solid'
    ? [
        'bg-aerial-accent text-aerial-bg-deep transition-all',
        'hover:bg-aerial-accent-hi hover:scale-[1.02] active:scale-[0.98]',
        'shadow-[0_8px_30px_-8px_oklch(78%_0.15_70/0.6)]',
      ]
    : [
        'border border-aerial-border bg-aerial-surface-hi/60 text-aerial-text',
        'hover:border-aerial-accent/50 transition-colors',
      ];

const alignClass = align === 'center' ? 'items-center text-center' : 'items-start text-left';

const sizeMb = release.downloadSize ? Math.round(release.downloadSize / 1024 / 1024) : 0;
const showBetaPointer = betaPointerHref && release.channel === 'stable';
---

<div class:list={['flex flex-col gap-3', alignClass]}>
  <a
    href={release.downloadUrl}
    class:list={[
      'inline-flex items-center gap-2 rounded-md font-semibold',
      ...toneClasses,
      sizeClass,
    ]}
  >
    <svg
      class="h-4 w-4"
      viewBox="0 0 16 16"
      fill="currentColor"
      aria-hidden="true"
    >
      <path
        d="M8 1.5a.5.5 0 0 1 .5.5v8.793l3.146-3.147a.5.5 0 1 1 .708.708l-4 4a.5.5 0 0 1-.708 0l-4-4a.5.5 0 0 1 .708-.708L7.5 10.793V2a.5.5 0 0 1 .5-.5Zm-6 12a.5.5 0 0 1 .5-.5h11a.5.5 0 0 1 0 1h-11a.5.5 0 0 1-.5-.5Z"
      ></path>
    </svg>
    Download Aerial {release.version}
  </a>
  {
    showMeta && (
      <p class="text-xs text-aerial-text-dim">
        {sizeMb > 0 && <>{sizeMb}&nbsp;MB · </>}
        {release.channel === 'beta' ? (
          <>
            Released {release.pubDateLabel} · Requires macOS&nbsp;{BETA_MIN_MACOS}+
            <br />
            Recommended for {BETA_RECOMMENDED_ON}
          </>
        ) : (
          <>
            Released {release.pubDateLabel} · macOS&nbsp;{release.minSystemVersion}+
            <br />
            Apple Silicon and Intel
          </>
        )}
      </p>
    )
  }
  {
    showBetaPointer && (
      <p class="text-xs text-aerial-text-dim">
        On {BETA_RECOMMENDED_ON}? We recommend{' '}
        <a href={betaPointerHref} class="text-aerial-link hover:text-aerial-link-hi">the beta</a>.
      </p>
    )
  }
</div>
