---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import MediaCard from '../../components/MediaCard.astro';

const features = (await getCollection('features')).sort(
  (a, b) => a.data.order - b.data.order,
);

// Pre-render all bodies so we can inline them.
const featureEntries = await Promise.all(
  features.map(async (f) => ({ entry: f, Content: (await render(f)).Content })),
);
---

<Base
  title="Features — Aerial"
  description="Every feature in Aerial 4: 240fps slowed for the desktop, your own videos, live feeds, multi-display, the visual overlay editor, global hotkeys, expansions, and more."
>
  <header class="mx-auto max-w-5xl px-6 pt-24 pb-12">
    <p class="text-sm font-semibold uppercase tracking-widest text-aerial-accent">Features</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-bold tracking-tight text-aerial-text">
      Everything Aerial does.
    </h1>
    <p class="mt-6 text-aerial-text-muted text-lg leading-relaxed max-w-3xl">
      Aerial is the macOS screensaver and live wallpaper for people who care about how their
      desktop looks when they're not using it. Below: every feature, with the honest trade-offs
      where they exist.
    </p>
  </header>

  <div class="mx-auto max-w-5xl px-6 pb-32 space-y-16">
    {
      featureEntries.map(({ entry, Content }) => {
        const hasMedia = Boolean(
          entry.data.image || entry.data.video || entry.data.placeholder,
        );
        return (
          <article id={entry.id} class="scroll-mt-24">
            {hasMedia && (
              <div class="mb-6 max-w-2xl">
                <MediaCard
                  image={entry.data.image}
                  video={entry.data.video}
                  videoPoster={entry.data.videoPoster}
                  alt={entry.data.alt ?? entry.data.title}
                  placeholder={entry.data.placeholder}
                  placeholderLabel={entry.data.title}
                />
              </div>
            )}
            <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-aerial-text">
              {entry.data.title}
            </h2>
            <p class="mt-3 text-aerial-text-muted text-lg italic">{entry.data.summary}</p>
            <div class="mt-5 prose prose-invert max-w-none text-aerial-text-muted leading-relaxed">
              <Content />
            </div>
          </article>
        );
      })
    }
  </div>
</Base>
