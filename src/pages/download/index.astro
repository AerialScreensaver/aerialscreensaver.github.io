---
import Base from '../../layouts/Base.astro';
import DownloadCTA from '../../components/DownloadCTA.astro';
import CommandBlock from '../../components/CommandBlock.astro';
import { getLatestRelease } from '../../lib/appcast';

const base = import.meta.env.BASE_URL;
const link = (path: string) => `${base.replace(/\/$/, '')}${path}`;
const release = await getLatestRelease();
---

<Base
  title={`Download Aerial ${release.version}`}
  description={`Aerial ${release.version} for macOS. Free, open source, auto-updates via Sparkle. macOS ${release.minSystemVersion}+.`}
>
  <section class="mx-auto max-w-3xl px-6 pt-24 pb-16">
    <p class="text-sm font-semibold uppercase tracking-widest text-aerial-accent">Download</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-bold tracking-tight text-aerial-text">
      Aerial {release.version}
    </h1>
    <p class="mt-6 text-aerial-text-muted text-lg leading-relaxed">
      One zip. Drag the app into <code class="text-aerial-text">/Applications</code>. Open it once
      and follow instructions. 
    </p>

    <div class="mt-10">
      <DownloadCTA variant="large" />
    </div>

    <div class="mt-14">
      <h2 class="text-aerial-text font-semibold text-lg">Or install with Homebrew</h2>
      <p class="mt-3 text-aerial-text-muted text-sm leading-relaxed">
        Prefer the command line? Aerial is on <a href="https://brew.sh" class="text-aerial-link">Homebrew</a>.
        Pick one — you don't need both.
      </p>

      <div class="mt-5 grid gap-5 md:grid-cols-2">
        <div>
          <CommandBlock command="brew install aerial" />
          <p class="mt-2.5 text-aerial-text-muted text-sm leading-relaxed">
            <strong class="text-aerial-text">Stable.</strong> Installs the latest stable version.
            Recommended.
          </p>
        </div>
        <div>
          <CommandBlock command="brew install aerial@beta" />
          <p class="mt-2.5 text-aerial-text-muted text-sm leading-relaxed">
            <strong class="text-aerial-text">Beta.</strong> Installs prerelease builds when one is
            available, latest if not — newest features, bugs expected.
          </p>
        </div>
      </div>

      <p class="mt-6 rounded-lg border border-aerial-border bg-aerial-surface/40 px-4 py-3 text-aerial-text-muted text-sm leading-relaxed">
        <strong class="text-aerial-text">Upgrading from Aerial 3.6.3?</strong> Launch the app once
        after installing — it will install and enable the new Aerial&nbsp;4 screensaver which is now distributed as an App Extension.
      </p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 text-sm">
      <div class="rounded-xl border border-aerial-border bg-aerial-surface/50 p-6">
        <h2 class="text-aerial-text font-semibold">Compatibility</h2>
        <ul class="mt-3 space-y-1 text-aerial-text-muted">
          <li>macOS {release.minSystemVersion} (Sequoia) or later</li>
          <li>Apple Silicon and Intel</li>
          <li>Single-display and multi-display setups</li>
        </ul>
      </div>
      <div class="rounded-xl border border-aerial-border bg-aerial-surface/50 p-6">
        <h2 class="text-aerial-text font-semibold">Updates</h2>
        <p class="mt-3 text-aerial-text-muted">
          Aerial uses <a href="https://sparkle-project.org/" class="text-aerial-link">Sparkle</a> for
          background auto-updates.
        </p>
      </div>
    </div>

    <div class="mt-16 text-aerial-text-muted text-sm">
      <h2 class="text-aerial-text font-semibold mb-3">After installing</h2>
      <ol class="list-decimal list-inside space-y-2">
        <li>Open <code class="text-aerial-text">Aerial.app</code> from <code class="text-aerial-text">/Applications</code>.</li>
        <li>Follow instructions to setup how you want Aerial to work, then customize what you want to see by checking the video library, or configure the various settings, all accessible from the icon in your menu bar.</li>
      </ol>
      <p class="mt-6">
        Stuck? Check the <a href={link('/faq')} class="text-aerial-link">FAQ</a> or open an issue on
        <a href="https://github.com/AerialScreensaver/Aerial/issues" class="text-aerial-link">GitHub</a>.
      </p>
    </div>

    <div class="mt-16 border-t border-aerial-border pt-10">
      <h2 class="text-aerial-text font-semibold text-lg">On an older Mac?</h2>
      <p class="mt-3 text-aerial-text-muted text-sm leading-relaxed">
        Aerial {release.version} requires macOS {release.minSystemVersion} (Sequoia) or later. If
        you're on an older system, two legacy builds are still available — neither is maintained,
        and neither will receive new features or fixes.
      </p>

      <div class="mt-6 grid gap-4 md:grid-cols-2 text-sm">
        <div class="rounded-xl border border-aerial-border bg-aerial-surface/40 p-5">
          <h3 class="text-aerial-text font-semibold">Aerial Companion 1.5.2</h3>
          <p class="mt-2 text-aerial-text-muted leading-relaxed">
            The last build of the previous-generation app, for Macs that can't run macOS 15.
          </p>
          <p class="mt-3 text-aerial-text-dim text-xs leading-relaxed">
            <strong class="text-aerial-text-muted">Important:</strong> after installing, open
            Companion's settings and <strong class="text-aerial-text-muted">disable
            auto-updates</strong> — otherwise it will prompt you to upgrade to a version your Mac
            can't run.
          </p>
          <a
            href="https://github.com/AerialScreensaver/Aerial/releases/download/v1.5.2/Aerial.Companion.zip"
            class="mt-4 inline-flex items-center gap-2 text-aerial-link hover:text-aerial-link-hi"
          >
            Download Aerial Companion 1.5.2
            <svg class="h-3 w-3" viewBox="0 0 12 12" aria-hidden="true">
              <path
                d="M4.5 2.5 8 6l-3.5 3.5"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                fill="none"></path>
            </svg>
          </a>
        </div>

        <div class="rounded-xl border border-aerial-border bg-aerial-surface/40 p-5">
          <h3 class="text-aerial-text font-semibold">Aerial 3.6.3 (.saver)</h3>
          <p class="mt-2 text-aerial-text-muted leading-relaxed">
            The classic standalone screensaver bundle from the original repository, for the oldest
            macOS versions.
          </p>
          <p class="mt-3 text-aerial-text-dim text-xs leading-relaxed">
            No companion app, no auto-updates — just the <code class="text-aerial-text-muted">.saver</code>
            installed via System Preferences.
          </p>
          <a
            href="https://github.com/JohnCoates/Aerial/releases/download/v3.6.3/Aerial.saver.zip"
            class="mt-4 inline-flex items-center gap-2 text-aerial-link hover:text-aerial-link-hi"
          >
            Download Aerial 3.6.3
            <svg class="h-3 w-3" viewBox="0 0 12 12" aria-hidden="true">
              <path
                d="M4.5 2.5 8 6l-3.5 3.5"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                fill="none"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-16 text-xs text-aerial-text-dim">
      <p>
        Direct download URL (also used by Sparkle):
        <a href={release.downloadUrl} class="break-all text-aerial-text-muted">{release.downloadUrl}</a>
      </p>
    </div>
  </section>
</Base>
