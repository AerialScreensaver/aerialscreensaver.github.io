---
import Base from '../../layouts/Base.astro';
import MediaCard from '../../components/MediaCard.astro';
---

<Base
  title="Expansions — Aerial"
  description="Community-made video packs for Aerial. Browse and install from inside the app's Video Library."
>
  <section class="mx-auto max-w-3xl px-6 pt-24 pb-32">
    <p class="text-sm font-semibold uppercase tracking-widest text-aerial-accent">Expansions</p>
    <h1 class="mt-3 text-4xl md:text-5xl font-bold tracking-tight text-aerial-text">
      Community video packs.
    </h1>
    <p class="mt-6 text-aerial-text-muted text-lg leading-relaxed">
      Aerial supports curated, community-made video packs called <em>expansions</em>. Each pack is
      its own source of videos with its own license and credits. The full catalog lives inside the
      app — open <strong class="text-aerial-text">Video Library → Expansions</strong> to browse and
      install. Nothing is auto-installed without your consent.
    </p>

    <div class="mt-10">
      <MediaCard
        imageSrc="expansions-browser.webp"
        alt="The Expansions browser inside Aerial's Video Library, showing Community 2026, Community 2020, Community Plus 2026, Future macOS Versions, and San Francisco packs from Magic Window."
      />
    </div>

    <div class="mt-10 rounded-xl border border-aerial-border bg-aerial-surface/50 p-6">
      <h2 class="text-aerial-text font-semibold">Featured pack</h2>
      <p class="mt-3 text-aerial-text-muted">
        <strong class="text-aerial-text">Joshua Michaels &amp; Hal Bergman</strong> shoot
        breathtaking aerial sequences over California, the American Southwest, New York, Monterey,
        and beyond — and have generously shared sets with the Aerial community since the early
        days. You can also support them by buying their commercial packs at
        <a href="https://magicwindow.app/aerial" class="text-aerial-link">magicwindow.app/aerial</a>.
      </p>
    </div>

    <div class="mt-10 text-aerial-text-muted">
      <h2 class="text-aerial-text font-semibold mb-3">Want to publish an expansion?</h2>
      <p>
        Reach out via
        <a href="https://github.com/AerialScreensaver/Aerial/issues" class="text-aerial-link">
          GitHub issues
        </a>
        — I'll point you at the format spec and help with the catalog entry.
      </p>
    </div>
  </section>
</Base>
